:: Sleep [nobr]

<<set _loc to $gamelocation>>

<<set _getuppassage to _loc>>

<<set _nosleep to false>>

<<if _loc is "Your Room">>

	You go to sleep on your bed.
	<<if $lastNpc>>
	_n.name joins you. You both snuggle together in a warm and content naked embrace.
	<</if>>
<<link "Continue">>
	<<goto "Wakeup">>
<</link>>
<</if>>