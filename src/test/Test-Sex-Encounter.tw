:: Test-Sex-Encounter [nobr]

<<if !$ui || !$ui.npc>>
	ERROR: ui.npc not set
	<<return>>
<</if>>
<<set _npc = $ui.npc>>
<<set _n = _npc>>
/* This is to be set to null at the end of each encounter.*/
<<set $n = _n>>

<<run setup.normalizeBodyparts($mc)>>
<<run setup.normalizeBodyparts(_n)>>

<<if !$mc.bodyparts && $mc.body>>
	<<set $mc.bodyparts = Object.keys($mc.body)>>
<</if>>
<<set $gamelocation = "Your Room">>
/* ensure room exists BEFORE UI */
<<if !$room>>
<<set $room = {
  type: "bedroom",
  location: "large floor",
  furnitureFlags: setup.getRoomFurnitureFlags("bedroom")
}>>
<</if>>

/* ensure sex exists */
<<SexMemory>>
/* local convenience copy */
<<set _sexCount = $npcMemory[_key].sexCount>>

<<set $sex.position = "Standing">>
<<set $sex.subject = null>>
<<set $sex.object = null>>
<<set $sex.engagedParts= { subject: [], object: [] }>>
<<set $sex.penetration = null>>
<<set $sex.phase = "tease">>
<<set $sex.history= []>>
<<set $sex.act= "Waiting">>



<<if $sex.roles.dom.name == $mc.name>>
  <<set $sex.role = "top">>
  <<run setup.updateSubjectObject($sex)>>
<<else>>
  <<set $sex.role = "bottom">>
  <<run setup.updateSubjectObject($sex)>>
<</if>>

/* ALWAYS rebind subject/object to current */
/*<<set $sex.subject = $mc>>
<<set $sex.object  = _n>> */



/* keep furniture flags synced (LOCATION-specific) */
<<set _furnObj = setup.RoomTypes.furniture[$room.location]>>
<<set $room.furnitureFlags = (_furnObj && _furnObj.flags) ? _furnObj.flags : []>>
<<set $sex.furnitureFlags  = $room.furnitureFlags>>






/*Arousal meter for both $mc and _n */
<<set _n.arousal = _n.arousal or 0>>
<<set $mc.arousal = $mc.arousal or 0>>




	<div id= "sex-container">
		<<SexEncounterUI>>
		<<RoomRelocationUI>>
	</div> 
	<div id="arousal-ui">
		<<ArousalUI>>
	</div>
	<hr>	
	<div id="npcsex-dialogue">
		<div id="intro" class="intro">
			<<if _sexCount == 1>>
				You both enter your room. You both strip naked, showing off your bare bodies to one another.
				You both know what you're in for, but it's always a bit awkward with someone new.
			<<elseif _sexCount >= 5>>
				You and <<= _n.name >> go to your hotel room.
				Almost professionally, you both strip until you are nude.
				<<= $proset.theyUp >> appears up for whatever you have in mind.
			<<else>>
				WTF THIS SHOULDN'T BE HERE! THERE IS AN ERROR IN THE GAME!
			<</if>>
		</div>
		<div id="log"><<include "PositionDialogue">></div>
		<hr>
	</div>

