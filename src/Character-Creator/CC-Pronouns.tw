:: CC-Pronouns [creation-page nobr] {"position":"1050,0","size":"100,100"}

<div id="cc-pronouns-root">
	<h1>Choose your Pronouns</h1>
	<br>
	<<set _pro = setup.pronouns >>
	<<CCChoiceButtons $mc "pronouns" _pro "#cc-pronouns-root" "CC-Pronouns">>
	<br>
	<<button "Confirm">>
		<<if !$mc.pronouns>>
			<span class="red">Please choose a pronoun.</span>
		<<else>>
			<<set $pages.pronouns = true>>
			<<goto "Index-CC">>
		<</if>>
	<</button>>
</div>
