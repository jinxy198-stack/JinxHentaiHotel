/* ----- GROPE BREAST ----- */
<<widget "GropeBreastQuote">>
/* guard */
	<<if !setup.gropebreastQuotes>>
		[Error] setup.gropebreastQuotes is not defined.
		<<return>>
	<</if>>
<<if !$sex or !$sex.roles or !_n>>
	<<return>>
<</if>>
<<if $sex.roles.dom and $sex.roles.dom.name == _n.name>>
	<<set _mode = "give">>
<<elseif $sex.roles.sub and $sex.roles.sub.name == _n.name>>
	<<set _mode = "receive">>
<<else>>
	<<return>>
<</if>>
	/* normalize inputs */
	<<set _pref = _n.sexpref || "Switch">>
	<<set _msize = $mc.breastsize >>
	<<set _nsize = _n.breastsize >>
	<<set _mage  = $mc.agegroup>>
	<<set _nage  = _n.ageGroup  || "Adult">>

	<<set _pool = null>>

	/* resolve pool */
	<<if _mode == "give">>
	<<set _pool = setup.gropebreastQuotes.bottom[_pref][_msize][_mage] 
	|| setup.gropebreastQuotes.bottom.Neutral>>
	<<else>>
		<<run _pool =
			(
				setup.gropebreastQuotes.top[_pref]
				&& setup.gropebreastQuotes.top[_pref][_nsize][_nage]
			)
			|| setup.gropebreastQuotes.top.Neutral
		>>
	<</if>>

	/* output */
	<<if _pool && _pool.length>>
		<<= either(..._pool)>>
	<<else>>
		[Error] GropeBreastQuote: empty dialogue pool.
	<</if>>

<</widget>>


/* ----- GROPE BUTT ----- */
<<widget "GropeButtQuote">>
	<<if !setup.gropebuttQuotes>>
		[Error] setup.gropebuttQuotes is not defined.
		<<return>>
	<</if>>

	<<if !_n or !$sex or !$sex.roles or !$sex.roles.dom or !$sex.roles.sub>>
		<<return>>
	<</if>>

	<<set _pref = _n.sexpref || "Neutral">>
	<<set _msize = $mc.assSize || "Round">>
	<<set _nsize = _n.assSize || "Round">>
	<<if !$sex or !$sex.roles or !_n>>
		<<return>>
	<</if>>

	<<if $sex.roles.dom and $sex.roles.dom.name == _n.name>>
		<<set _mode = "give">>
	<<elseif $sex.roles.sub and $sex.roles.sub.name == _n.name>>
		<<set _mode = "receive">>
	<<else>>
		<<return>>
	<</if>>
	<<set _pool = null>>

	<<if _mode == "give">>
		<<set _pool =
			(
				setup.gropebuttQuotes.bottom[_nsize]
				&& setup.gropebuttQuotes.bottom[_nsize][_pref]
			)
			|| 
			(
				setup.gropebuttQuotes.bottom[_nsize]
				&& setup.gropebuttQuotes.bottom[_nsize].Neutral
			)

		>>
	<<else>>
		<<set _pool =
			(
				setup.gropebuttQuotes.top[_msize]
				&& setup.gropebuttQuotes.top[_msize][_pref]
			)
			|| 
			(
				setup.gropebuttQuotes.bottom[_nsize]
				&& setup.gropebuttQuotes.bottom[_nsize].Neutral
			)

		>>
	<</if>>

	<<if Array.isArray(_pool) && _pool.length>>
		<<= either(..._pool)>>
	<<else>>
		[Error] GropeButtQuote: empty dialogue pool.
	<</if>>
<</widget>>


/* ----- HANDJOB ----- */
<<widget "HandjobQuote">>
	/* guard */
	<<if !setup.handjobQuotes>>
		[Error] setup.handjobQuotes is not defined.
		<<return>>
	<</if>>

	/* normalize inputs */
	<<set _pref = _n.sexpref || "Neutral">>
	<<set _msize = $mc.penislength || "average">>
	<<set _mage  = $mc.agegroup>>
	<<if !$sex or !$sex.roles or !_n>>
		<<return>>
	<</if>>

	<<if $sex.roles.dom and $sex.roles.dom.name == _n.name>>
		<<set _mode = "give">>
	<<elseif $sex.roles.sub and $sex.roles.sub.name == _n.name>>
		<<set _mode = "receive">>
	<<else>>
		<<return>>
	<</if>>
	<<set _pool = null>>

	/* resolve pool */
	<<if _mode == "give">>
		<<set _pool = setup.handjobQuotes.bottom[_pref]
			|| setup.handjobQuotes.bottom.Neutral
		>>
	<<else>>
		<<if _msize == "tiny">>
			<<run _pool =
				(
					setup.handjobQuotes.top[_pref]
					&& setup.handjobQuotes.top[_pref].tiny
					&& setup.handjobQuotes.top[_pref].tiny[_mage]
				)
				|| setup.handjobQuotes.top.Neutral
			>>
		<<else>>
			<<run _pool =
				(
					setup.handjobQuotes.top[_pref]
					&& setup.handjobQuotes.top[_pref][_msize]
				)
				|| setup.handjobQuotes.top.Neutral
			>>
		<</if>>
	<</if>>

	/* output */
	<<if _pool && _pool.length>>
		<<= either(..._pool)>>
	<<else>>
		[Error] HandjobQuote: empty dialogue pool.
	<</if>>

<</widget>>

