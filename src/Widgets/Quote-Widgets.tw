/* ----- SUCK FOOT ----- */
<<widget "SuckFootQuote">>
	/* guard */
	<<if !setup.suckfootQuotes>>
		[Error] setup.suckfootQuotes is not defined.
		<<return>>
	<</if>>

	/* normalize inputs */
	<<set _pref = _n.sexpref || "Neutral">>
	<<if !$sex or !$sex.roles or !_n>>
		<<return>>
	<</if>>

	<<if $sex.roles.dom and $sex.roles.dom.name == _n.name>>
		<<set _mode = "give">>
	<<elseif $sex.roles.sub and $sex.roles.sub.name == _n.name>>
		<<set _mode = "receive">>
	<<else>>
	<<return>>
	<</if>>
	<<set _pool = null>>

	/* resolve pool */
	<<if _mode == "give">>
		<<set _pool = setup.suckfootQuotes.bottom[_pref]
			|| setup.suckfootQuotes.bottom.Neutral
		>>
	<<else>>
			<<run _pool =
				(
					setup.suckfootQuotes.top[_pref]
				)
				|| setup.suckfootQuotes.top.Neutral.default
			>>

	<</if>>

	/* output */
	<<if _pool && _pool.length>>
		<<= either(..._pool)>>
	<<else>>
		[Error] SuckfootQuote: empty dialogue pool.
	<</if>>
<</widget>>

