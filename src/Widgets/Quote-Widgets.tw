/* ----- FEEL STOMACH ----- */
<<widget "FeelStomachQuote">>

	/* guard */
	<<if !setup.feelstomachQuotes>>
		[Error] setup.feelstomachQuotes is not defined.
		<<return>>
	<</if>>

	/* normalize inputs */
	<<set _pref = _n.sexpref || "Neutral">>
	<<if !$sex or !$sex.roles or !_n>>
		<<return>>
	<</if>>

	<<if $sex.roles.dom and $sex.roles.dom.name == _n.name>>
		<<set _mode = "give">>
	<<elseif $sex.roles.sub and $sex.roles.sub.name == _n.name>>
		<<set _mode = "receive">>
	<<else>>
		<<return>>
	<</if>>
		
	<<set _body = $mc.physique || "Average">>
	<<set _material = _n.body.Bodymaterial || null>>

	<<set _pool = null>>

	/* resolve pool */
	<<if _mode == "give">>
		<<set _pool = setup.feelstomachQuotes.bottom[_body]
			|| setup.feelstomachQuotes.bottom.Neutral
		>>
	<<else>>
			<<run _pool =
				(
					setup.feelstomachQuotes.top[_material]
				)
				|| setup.feelstomachQuotes.top.Neutral.default
			>>
	<</if>>

	/* output */
	<<if _pool && _pool.length>>
		<<= either(..._pool)>>
	<<else>>
		[Error] FeelStomach: empty dialogue pool.
	<</if>>
<</widget>>

