<</widget>>


//to compare the heights of the mc and npc, or two npc's
<<widget "HeightCompare">>
    <<script>>
    const rank = {
    "Very Short": 1,
    "Short": 2,
    "Average": 3,
    "Tall": 4,
    "Very Tall": 5
    };

    const mcH  = rank[$mc.height];
    const npcH = rank[_n.height];

    return mcH > npcH ? 1 : mcH < npcH ? -1 : 0;
    <</script>>
<</widget>>

//to compare the size of the mc and npc, or two npc's
<<widget "SizeCompare">>
    <<script>>
    const rank = {
    "Tiny": 1,
    "Small": 2,
    "Average": 3,
    "Large": 4,
    "Huge": 5
    };

    const mcS  = rank[$mc.penislength];
    const npcS = rank[_n.penislength];

    return mcS > npcS ? 1 : mcS < npcS ? -1 : 0;
    <</script>>
<</widget>>

<<widget "SexMemory">>
    /* ensure global memory object exists */
	<<set $npcMemory = $npcMemory or {}>>
    /* choose a key for this NPC */
    <<set _key = _n.id or _n.name>>

	/* ensure memory entry exists */
	<<set $npcMemory[_key] = $npcMemory[_key] or {}>>

	/* ensure properties exist */
	<<set $npcMemory[_key].interacted = $npcMemory[_key].interacted or false>>
	<<set $npcMemory[_key].times      = $npcMemory[_key].times      or 0>>
	<<set $npcMemory[_key].sexCount   = $npcMemory[_key].sexCount   or 0>>

	/* update values */
	<<set $npcMemory[_key].interacted = true>>
	<<set $npcMemory[_key].times     += 1>>
	<<set $npcMemory[_key].sexCount  += 1>>
<</widget>> 

<<widget "tooltip">>
	<<set _label = _args[0]>>
	<<set _tip = _args[1]>>
	<span class="tooltip-term" tabindex="0" @data-tooltip="_tip"><<print _label>></span>
<</widget>>

/*Makes sure the mc has the specific trait */
<<widget "EnsureMCTrait">>
	<<set _trait = _args[0]>>

	<<if !Array.isArray($mc.traits)>>
		<<set $mc.traits = []>>
	<</if>>

	<<if !$mc.traits.includes(_trait)>>
		<<run $mc.traits.push(_trait)>>
	<</if>>
<</widget>>

<<widget "RandomTraits">>
	<<set _char = _args[0]>>
	<<set _max = _args[1] || 2>>
	<<set _exact = _args[2] || false>>

	<<if !_char>>
		<span class="error">[Error] RandomTraits needs a character object.</span>
	<<else>>
		<<run setup.traits.addRandomTraits(_char, _max, { exact: _exact })>>
	<</if>>
<</widget>>