<<widget "AdultWoman">>
    <<set 
        $mc.name to "Mary",
        $mc.nickname to "Sexy",
        $mc.surname to "Stu",
        $mc.species to "Human",
        $mc.gender to "Female",
        $mc.sexu to "Bisexual",
        $mc.pronouns to "She/Her",
        $mc.age to "27",
        $heterochromia to false,
        $mc.eyes to "Brown",
        $mc.hair to {},
        $mc.hair.length to "Short",
        $mc.hair.color to "Black",
        $mc.hair.style to "Buzz cut",
        $mc.facefeatures to ["A mole"],
        $mc.skin.color to "Tan",
        $mc.skin.features to [],
        $mc.bodyheight to "Tall",
        $mc.physique to "Thin",
        $mc.breastsize to "Large",
        $mc.personality to "Kind",
        $mc.genitals to "Vagina",
        $mc.genitaltype to "Loose",
        $mc.assSize to "Average",
        $mc.sexpref to "Versatile",
        $mc.virgin to true
    >>
    <<AgeGroupSet>>
    <<SetTrans>>
    <<create-body $mc>>
<</widget>>

<<widget "AdultMan">>
    <<set 
        $mc.name to "Gary",
        $mc.nickname to "Sexy",
        $mc.surname to "Stu",
        $mc.species to "Human",
        $mc.gender to "Male",
        $mc.sexu to "Bisexual",
        $mc.pronouns to "He/Him",
        $mc.age to "27",
