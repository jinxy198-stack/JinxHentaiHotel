:: Against-Wall-Dialogue [nobr Dialogue] {"position":"975,1225","size":"100,100"}

<<set _npc = _n>>
<<PronounsSet>>
/* Supposed to be facing each other against the wall. */

<<if $sex.role == "Top">>
    <<=either(
        "You're standing behind _n.name as they brace themself against the $room.location."
    )>>
<<else>>
    <<=either(
        "You'r back is against the $room.location with _n.name in front of you.",
        "_n.name leans you against the $room.location."
    )>>
<</if>>
