:: Laid-Across-Oral-Service-Dialogue [nobr]

    <<if $sex.role == "Top">>
        <<ref _top 'subjCap'>> <<verb _top 'push'>> <<ref _bottom 'subj'>> back on the <<= _spot>> and <<verb _top 'step'>> up towards <<pro _bottom 'poss'>> head.
    <<elseif $sex.role == "Bottom">>
        <<ref _bottom 'subjCap'>> <<verb _bottom 'lie'>> back on the <<= _spot>> as <<ref _top 'subj'>> <<verb _top 'step'>> up towards <<pro _bottom 'poss'>> head.
    <</if>>
