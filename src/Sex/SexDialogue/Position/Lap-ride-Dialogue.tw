:: Lap-ride-Dialogue [nobr]

<<if $sex.position == "Lap ride">>
	<<= either(
		"<<ref _bottom 'subjCap'>> <<verb _bottom 'sit'>> on <<ref _top 'poss'>> lap, looking at <<ref _top 'obj'>>."
	) >>
<<elseif $sex.position == "Reverse Lap ride">>
	<<= either(
		"<<ref _bottom 'subjCap'>> <<verb _bottom 'sit'>> on <<ref _top 'poss'>> lap, facing away from <<ref _top 'obj'>>."
	) >>
<</if>>