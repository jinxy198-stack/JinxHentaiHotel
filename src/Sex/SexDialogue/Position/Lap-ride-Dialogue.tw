:: Lap-ride-Dialogue [nobr]

<<if $sex.position == "Lap ride">>
	<<= either(
		"<<gram _bottom 'subjCap'>> <<verb _bottom 'sit'>> on <<gram _top 'poss'>> lap, looking at <<gram _top 'obj'>>."
	) >>
<<elseif $sex.position == "Reverse Lap ride">>
	<<= either(
		"<<gram _bottom 'subjCap'>> <<verb _bottom 'sit'>> on <<gram _top 'poss'>> lap, facing away from <<gram _top 'obj'>>."
	) >>
<</if>>