:: Pet-Ears-Dialogue [nobr Dialogue] {"position":"1200,1675","size":"100,100"}

<<set _npc = _n>>
<<PronounsSet>>
<<if $sex.role == "Bottom">>
    <<= either(
 	"_n.name pets your <<= $mc.body.Ear.toLowerCase()>>."
    )>>
	    
<<elseif $sex.role == "Top">>
	
    <<= either(
    "You pet _n.name's <<= _n.body.Ear.toLowerCase()>>."
    )>>
    
<</if>>


