:: Grope-Butt-Dialogue [nobr Dialogue] {"position":"1000,1675","size":"100,100"}
<<set _npc = _n>>
<<PronounsSet>>

    <<if $sex.role == "Bottom">>
	    <<=either(
 	        "_n.name grabs your <<=$mc.assSize.toLowerCase()>> ass."
        )>>
    <<elseif $sex.role == "Top">>
	    <<=either(
            "You grab _n.name's <<=_n.assSize.toLowerCase()>> ass."
        )>>
    <</if>>


