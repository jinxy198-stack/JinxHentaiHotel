:: Handjob-Quote [nobr Dialogue] {"position":"1700,1700","size":"100,100"}


<<if $sex.role == "Bottom">>
	<<set _mode = "Bottom">>
<<elseif $sex.role == "Top">>
	<<set _mode = "Top">>
<</if>>
<<set _pref = _n.sexpref || "Neutral">>
<<set _size = $mc.penislength || "Average">>
<<set _age  = $mc.ageGroup>>
<<set _personality = _n.personality>>

<<set _pool = null>>

<<if _mode == "Top">>
	<<set _pool =
		setup.handjobQuotes.Bottom[_pref]
		|| setup.handjobQuotes.Bottom.Neutral
	>>
<<elseif _mode == "Bottom">>
	<<if _personality == "Childlike">>
		<<set _pool =
			setup.handjobQuotes.Top[_personality]
		>>
	<<elseif _size == "Tiny">>
		<<set _pool =
			(
				setup.handjobQuotes.Top[_pref]
				&& setup.handjobQuotes.Top[_pref].Tiny
				&& setup.handjobQuotes.Top[_pref].Tiny[_age]
			)
			|| setup.handjobQuotes.Top.Neutral
		>>
	<<else>>
		<<set _pool =
			(
				setup.handjobQuotes.Top[_pref]
				&& setup.handjobQuotes.Top[_pref][_size]
			)
			|| setup.handjobQuotes.Top.Neutral
		>>
	<</if>>
<</if>>

<<if _pool && _pool.length>>
	<<=either(..._pool)>>
<<else>>
	[Error] No handjob quote pool found.
	(mode=<<=_mode>>, pref=<<=_pref>>, age=<<=_age>>, size=<<=_size>>,personality=<<=_personality>>)
<</if>>

