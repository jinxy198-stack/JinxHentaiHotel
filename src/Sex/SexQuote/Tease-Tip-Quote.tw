:: Tease-Tip-Quote [nobr]

<<set _pref = _n.sexpref || "Switch">>
<<set _msize = $mc.penislength || "Average">>
<<set _personality = _n.personality>>

<<set _mode = $sex.role>>
<<set _position = $sex.position >>

<<set _pool = null>>

<<if _mode == "Bottom">>
	<<set _pool = setup.TeaseTipQuotes>>
<<elseif _mode == "Top">>
	<<set _pool = setup.TeaseTipQuotes>>
<</if>>

<<if _pool && _pool.length>>
	<<=either(..._pool)>>
<<else>>
	[Error] No Tease tip quote pool found.
    (mode=<<=_mode>>, pref=<<=_pref>>, personality=<<=_personality>>)
<</if>>