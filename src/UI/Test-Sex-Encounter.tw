:: Test-Sex-Encounter [nobr]
<<if !$ui or typeof $ui !== "object">>
	<<set $ui = {}>>
<</if>>

<<if !$ui.npc and $bootyCallNpc>>
	<<set $ui.npc = clone($bootyCallNpc)>>
<</if>>

<<if !$ui.npc and $lastNpc>>
	<<set $ui.npc = clone($lastNpc)>>
<</if>>

<<if !$ui.npc>>
	ERROR: ui.npc not set
	<<return>>
<</if>>

<<set _npc = $ui.npc>>
<<set _n = _npc>>
<<set $n = _n>>
<<set $bootyCallNpc = null>>

/* normalize both actors once */
<<run setup.normalizeActor($mc)>>
<<run setup.normalizeActor(_n)>>

/* ensure room exists BEFORE UI */
<<GetRoom>>

/* ensure sex exists */
<<SexMemory>>

/* local convenience copy */
<<set _sexCount = $npcMemory[_key].sexCount>>

<<set $sex.position = "Standing">>
<<set $sex.Top = null>>
<<set $sex.Bottom = null>>
<<set $sex.engagedParts = { Top: [], Bottom: [] }>>
<<set $sex.penetration = null>>
<<set $sex.phase = "tease">>
<<set $sex.history = []>>
<<set $sex.act = "Waiting">>

<<if $sex.roles.dom.name == $mc.name>>
	<<set $sex.role = "Top">>
	<<run setup.updateTopBottom($sex)>>
<<elseif $sex.roles.dom.name == _n.name>>
	<<set $sex.role = "Bottom">>
	<<run setup.updateTopBottom($sex)>>
<</if>>

/* normalize Top/Bottom after role assignment */
<<run setup.normalizeSexActors($sex)>>

<<set _h = "<<HeightCompare>>">>
<<set _s = "<<SizeCompare>>">>

/* keep furniture flags synced (LOCATION-specific) */
<<set _furnObj = setup.RoomTypes.furniture[$room.location]>>
<<set $room.furnitureFlags = (_furnObj && _furnObj.flags) ? _furnObj.flags : []>>
<<set $sex.furnitureFlags = $room.furnitureFlags>>

/* arousal meter for both */
<<set _n.arousal = 0>>
<<set $mc.arousal = 0>>

<div id="sex-container">
	<<SexEncounterUI>>
	<<RoomRelocationUI>>
</div>

<div id="arousal-ui">
	<<ArousalUI>>
</div>

<hr>

<div id="npcsex-dialogue">
	<div id="intro" class="intro">
		<<if _sexCount == 1>>
			You both enter <<= $gamelocation.toLowerCase() >>. You both strip naked, showing off your bare bodies to one another.
			You both know what you're in for, but it's always a bit awkward with someone new.

			<<if _h is 1>>
				$mc.name is taller.
			<<elseif _h is -1>>
				_n.name is taller.
			<<else>>
				_n.name and $mc.name are both the same height.
			<</if>>
		<<elseif _sexCount >= 2>>
			You and <<=_n.name>> go to <<= $gamelocation.toLowerCase() >>.
			Almost professionally, you both strip until you are nude.
			<<=$proset.theyUp>> appears up for whatever you have in mind.
		<<else>>
			WTF THIS SHOULDN'T BE HERE! THERE IS AN ERROR IN THE GAME!
		<</if>>
	</div>

	<div id="log"><<include "PositionDialogue">></div>
	<hr>
</div>